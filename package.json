{
  "name": "crm-artisan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "node ./scripts/dev-local.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "npm run test:integration:ui && npm run test:integration:db",
    "test:integration:ui": "vitest run tests/integration/signup-form.test.tsx",
    "test:integration:db": "node ./scripts/with-local-supabase.mjs vitest run tests/integration/account-billing.test.ts tests/integration/job-site-limits.test.ts tests/integration/clients-crud.test.ts tests/integration/dashboard-foundation.test.ts",
    "test:e2e": "node ./scripts/with-local-supabase.mjs playwright test",
    "test:e2e:browser": "node ./scripts/with-local-supabase.mjs playwright test --project=chromium-no-auth --project=chromium-auth",
    "test:e2e:auth": "node ./scripts/with-local-supabase.mjs playwright test tests/auth.spec.ts --project=chromium-no-auth",
    "test:e2e:flows": "node ./scripts/with-local-supabase.mjs playwright test tests/clients.spec.ts tests/quotes.spec.ts tests/subscription-regression.spec.ts --project=chromium-auth",
    "test:security": "node ./scripts/with-local-supabase.mjs playwright test --project=chromium-security --project=api-security",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^19.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
